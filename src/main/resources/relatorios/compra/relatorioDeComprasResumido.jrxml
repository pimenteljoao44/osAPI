<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="RelatorioDeCompras" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20"
              bottomMargin="20" uuid="d5e6b960-7f91-4f9f-bc60-7a34888edc56">

    <!-- Parâmetros -->
    <parameter name="fornecedor" class="java.lang.Integer"/>
    <parameter name="funcionario" class="java.lang.Integer"/>
    <parameter name="dataInicial" class="java.lang.String"/>
    <parameter name="dataFinal" class="java.lang.String"/>
    <parameter name="formaPagamento" class="java.lang.String"/>

    <!-- Consulta SQL -->
    <queryString>
        <![CDATA[
           SELECT
               c.compr_id,
               c.data_compra,
               c.valor_total,
               c.quantidade_total,
               pess.nome AS fornecedor_nome,
               p_func.nome AS funcionario_nome,
               i.quantidade,
               i.valor as preco,
               p.nome AS produto_nome
           FROM compra c
           LEFT JOIN fornecedor f ON f.id = c.fornecedor_id
           LEFT JOIN pessoa pess ON pess.id = f.pessoa_id
           LEFT JOIN funcionario func ON func.funcionario_id = c.funcionario_funcionario_id
           LEFT JOIN pessoa p_func ON p_func.id = func.pessoa_id
           LEFT JOIN item_compra i ON i.compra_id = c.compr_id
           LEFT JOIN produto p ON p.prod_id = i.produto_prod_id
           WHERE (c.fornecedor_id = $P{fornecedor} OR $P{fornecedor} IS NULL)
             AND (c.funcionario_funcionario_id = $P{funcionario} OR $P{funcionario} IS NULL)
             AND (c.data_compra >= CAST($P{dataInicial} AS DATE) OR $P{dataInicial} IS NULL)
             AND (c.data_compra <= CAST($P{dataFinal} AS DATE) OR $P{dataFinal} IS NULL)
             AND (c.forma_pagamento = $P{formaPagamento} OR $P{formaPagamento} IS NULL);

        ]]>
    </queryString>

    <!-- Campos do banco de dados -->
    <field name="compr_id" class="java.lang.Integer"/>
    <field name="data_compra" class="java.sql.Timestamp"/>
    <field name="valor_total" class="java.math.BigDecimal"/>
    <field name="quantidade_total" class="java.math.BigDecimal"/>
    <field name="fornecedor_nome" class="java.lang.String"/>
    <field name="funcionario_nome" class="java.lang.String"/>
    <field name="produto_nome" class="java.lang.String"/>
    <field name="quantidade" class="java.math.BigDecimal"/>
    <field name="preco" class="java.math.BigDecimal"/>

    <!-- Cabeçalho com estilo profissional -->
    <title>
        <band height="80">
            <image>
                <reportElement x="0" y="0" width="100" height="60" />
                <imageExpression><![CDATA["relatorios/venda/LogoMarmoraria.png"]]></imageExpression>
            </image>
            <staticText>
                <reportElement x="100" y="0" width="455" height="60" />
                <textElement textAlignment="Center">
                    <font size="24" isBold="true" isUnderline="true"/>
                </textElement>
                <text><![CDATA[Relatório de Compras]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="65" width="555" height="1"/>
                <graphicElement>
                    <pen lineWidth="1.0" lineColor="#000000"/>
                </graphicElement>
            </line>
        </band>
    </title>

    <!-- Cabeçalhos das colunas -->
    <columnHeader>
        <band height="35">
            <staticText>
                <reportElement x="0" y="0" width="60" height="35" />
                <textElement><font size="12" isBold="true" /></textElement>
                <text><![CDATA[ID Compra]]></text>
            </staticText>
            <staticText>
                <reportElement x="60" y="0" width="120" height="35" />
                <textElement><font size="12" isBold="true" /></textElement>
                <text><![CDATA[Fornecedor]]></text>
            </staticText>
            <staticText>
                <reportElement x="180" y="0" width="100" height="35" />
                <textElement><font size="12" isBold="true" /></textElement>
                <text><![CDATA[Funcionário]]></text>
            </staticText>
            <staticText>
                <reportElement x="280" y="0" width="100" height="35" />
                <textElement><font size="12" isBold="true" /></textElement>
                <text><![CDATA[Produto]]></text>
            </staticText>
            <staticText>
                <reportElement x="380" y="0" width="60" height="35" />
                <textElement><font size="12" isBold="true" /></textElement>
                <text><![CDATA[Quantidade]]></text>
            </staticText>
            <staticText>
                <reportElement x="440" y="0" width="55" height="35" />
                <textElement><font size="12" isBold="true" /></textElement>
                <text><![CDATA[Preço]]></text>
            </staticText>
            <staticText>
                <reportElement x="495" y="0" width="60" height="35" />
                <textElement><font size="12" isBold="true" /></textElement>
                <text><![CDATA[Total]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- Detalhes -->
    <detail>
        <band height="30">
            <textField>
                <reportElement x="0" y="0" width="60" height="30" />
                <textFieldExpression><![CDATA[$F{compr_id}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="60" y="0" width="120" height="30" />
                <textFieldExpression><![CDATA[$F{fornecedor_nome}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="180" y="0" width="100" height="30" />
                <textFieldExpression><![CDATA[$F{funcionario_nome}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="280" y="0" width="100" height="30" />
                <textFieldExpression><![CDATA[$F{produto_nome}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="380" y="0" width="60" height="30" />
                <textFieldExpression><![CDATA[$F{quantidade}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="440" y="0" width="55" height="30" />
                <textFieldExpression><![CDATA[new java.text.DecimalFormat("R$ #,##0.00").format($F{preco})]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="495" y="0" width="60" height="30" />
                <textFieldExpression><![CDATA[new java.text.DecimalFormat("R$ #,##0.00").format($F{valor_total})]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- Rodapé com data e hora de emissão -->
    <pageFooter>
        <band height="50">
            <textField>
                <reportElement x="0" y="0" width="555" height="50" />
                <textFieldExpression><![CDATA["Relatório gerado em " + new java.text.SimpleDateFormat("dd 'de' MMMM 'de' yyyy 'às' HH:mm:ss", new java.util.Locale("pt", "BR")).format(new java.util.Date())]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>
